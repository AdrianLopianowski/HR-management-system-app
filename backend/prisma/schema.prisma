generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  users     User[]   
}

model User {
  id          Int        @id @default(autoincrement())
  email       String     @unique
  name        String?
  role        String     @default("USER") // np. ADMIN, USER
  createdAt   DateTime   @default(now())
  
  // Relacja z Workspace
  workspaceId Int?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
}